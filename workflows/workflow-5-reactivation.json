            "reactivation_sent": "TRUE",
            "last_message_sent": "={{ new Date().toISOString() }}",
            "message_count": "={{ (parseInt($('Filter Inactive Patients').item.json.message_count) || 0) + 1 }}",
            "updated_at": "={{ new Date().toISOString() }}"
          },
          "matchingColumns": ["id"],
          "schema": []
        },
        "options": {}
      },
      "id": "55555555-5555-5555-5555-000000000007",
      "name": "Update Patient Record",
