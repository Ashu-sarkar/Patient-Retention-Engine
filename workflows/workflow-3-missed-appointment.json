    {
      "parameters": {
        "jsCode": "// Filter missed appointments and calculate the Twilio template to send.\nconst items = $input.all();\nconst tz = $env.TIMEZONE || 'Asia/Kolkata';\nconst maxMessages = parseInt($env.MAX_MESSAGE_COUNT) || 5;\nconst minHours = parseInt($env.MIN_HOURS_BETWEEN_MESSAGES) || 23;\nconst now = new Date();\nconst todayStr = now.toLocaleDateString('en-CA', { timeZone: tz });\nconst todayDate = new Date(todayStr);\nconst actionable = [];\nfor (const item of items) {\n  const p = item.json;\n  if (!p.follow_up_date) continue;\n  const followUpDate = new Date(new Date(p.follow_up_date).toLocaleDateString('en-CA', { timeZone: tz }));\n  if (isNaN(followUpDate.getTime()) || followUpDate >= todayDate) continue;\n  const status = p.status || 'pending';\n  if (status === 'completed' || status === 'inactive') continue;\n  const daysOverdue = Math.floor((todayDate - followUpDate) / (1000 * 60 * 60 * 24));\n  const hasValidPhone = p.phone && /^\\+[1-9]\\d{6,14}$/.test(p.phone);\n  const msgCount = parseInt(p.message_count) || 0;\n  let recentlyMessaged = false;\n  if (p.last_message_sent) {\n    const hoursSince = (now - new Date(p.last_message_sent)) / (1000 * 60 * 60);\n    recentlyMessaged = hoursSince < minHours;\n  }\n  const doctor = p.doctor_name || $env.DEFAULT_DOCTOR_NAME || 'your doctor';\n  const clinic = p.clinic_name || $env.DEFAULT_CLINIC_NAME || 'our clinic';\n  const name = p.name || 'there';\n  const reminderContentSid = $env.TWILIO_CONTENT_PATIENT_REMINDER || '';\n  if (daysOverdue >= 7) {\n    actionable.push({ json: { ...p, _action: 'mark_missed', _days_overdue: daysOverdue, _workflow: 'workflow-3-missed-appointment' } });\n  } else if (daysOverdue === 3 && hasValidPhone && msgCount < maxMessages && !recentlyMessaged) {\n    const scheduledDate = todayStr;\n    actionable.push({ json: { ...p, _action: 'send_nudge', _days_overdue: daysOverdue, _workflow: 'workflow-3-missed-appointment', _message_type: 'missed_appointment_nudge', _scheduled_date: scheduledDate, _to_phone: 'whatsapp:' + p.phone, _name: name, _doctor_name: doctor, _clinic_name: clinic, _content_sid: reminderContentSid || $env.TWILIO_CONTENT_MISSED_NUDGE || '', _content_variables: JSON.stringify({ '1': name, '2': doctor, '3': clinic }), _message_body: `Hi ${name}, ${doctor} wanted us to check in on you. It has been a few days since your scheduled follow-up at ${clinic}. Reply BOOK if you would like to arrange a new appointment.` } });\n  } else if (daysOverdue === 1 && hasValidPhone && msgCount < maxMessages && !recentlyMessaged) {\n    const scheduledDate = todayStr;\n    actionable.push({ json: { ...p, _action: 'send_recovery', _days_overdue: daysOverdue, _workflow: 'workflow-3-missed-appointment', _message_type: 'missed_appointment_recovery', _scheduled_date: scheduledDate, _to_phone: 'whatsapp:' + p.phone, _name: name, _doctor_name: doctor, _content_sid: reminderContentSid || $env.TWILIO_CONTENT_MISSED_RECOVERY || '', _content_variables: JSON.stringify({ '1': name, '2': doctor }), _message_body: `Hi ${name}, we noticed you missed your follow-up appointment with ${doctor} yesterday. Would you like to reschedule? Reply RESCHEDULE and our team will get back to you.` } });\n  }\n}\nif (actionable.length === 0) return [{ json: { _skip: true, reason: 'No missed appointments to process', todayStr } }];\nreturn actionable;"
      },
