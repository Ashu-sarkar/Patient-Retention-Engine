                "conditions": [
                  {
                    "id": "action-send-nudge",
                    "leftValue": "={{ $json._action }}",
                    "rightValue": "send_nudge",
                    "operator": { "type": "string", "operation": "equals" }
                  }
                ],
                "combinator": "and"
              },
              "renameOutput": true,
              "outputKey": "Send Nudge"
            }
          ]
        },
        "options": {}
      },
