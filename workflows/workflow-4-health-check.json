      ],
      "credentials": {
        "postgres": {
          "id": "U3Ok26tbDrmjkBQr",
          "name": "Supabase DB"
        }
      }
    },
    {
      "parameters": {
        "operation": "insert",
        "schema": {
          "__rl": true,
          "value": "public",
          "mode": "list"
        },
        "table": {
          "__rl": true,
