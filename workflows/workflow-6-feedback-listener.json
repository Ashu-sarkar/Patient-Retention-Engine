    {
      "parameters": {
        "jsCode": "// Find patient matching the inbound phone number and prepare update\nconst allPatients = $input.all();\n\n// Retrieve the classified message data from the Parse node\nconst parsed = $('Parse and Classify Message').first().json;\nconst inboundPhone = parsed._from_phone;\nconst classification = parsed._classification;\nconst messageBody = parsed._message_body;\nconst receivedAt = parsed._received_at;\n\n// Normalise phone for comparison (strip non-digits, add + if needed)\nfunction normalisePhone(phone) {\n  if (!phone) return '';\n  const stripped = phone.replace(/[\\s\\-().]/g, '').replace(/^whatsapp:/i, '');\n  return stripped.startsWith('+') ? stripped : '+' + stripped;\n}\n\nconst normInbound = normalisePhone(inboundPhone);\n\n// Find matching patient\nconst matchedPatient = allPatients.find(item => {\n  const normPatient = normalisePhone(item.json.phone || '');\n  return normPatient === normInbound;\n});\n\nif (!matchedPatient) {\n  return [{\n    json: {\n      _found: false,\n      _from_phone: inboundPhone,\n      _classification: classification,\n      _message_body: messageBody,\n      _received_at: receivedAt,\n      _log_message: `Unrecognised sender: ${inboundPhone}`\n    }\n  }];\n}\n\n// Determine auto-reply text based on classification\nconst patientName = matchedPatient.json.name || 'there';\nlet autoReply = null;\n\nif (classification === 'confirmed') {\n  autoReply = `Thank you, ${patientName}! ✅ We've noted that you'll be coming in for your appointment. See you then!\\n\\nIf anything changes, feel free to message us.`;\n} else if (classification === 'cancelled' || messageBody.toLowerCase().includes('reschedule')) {\n  autoReply = `Hi ${patientName}, no problem at all! 😊 We've noted that you'd like to reschedule. A member of our team will reach out to you shortly to arrange a new time.\\n\\nThank you for letting us know!`;\n} else if (classification === 'help') {\n  autoReply = `Hi ${patientName}, we're sorry to hear that. 🙏 Please stay calm — we've flagged this for our team and someone will reach out to you very soon. If this is an emergency, please call your nearest hospital.`;\n}\n\nreturn [{\n  json: {\n    _found: true,\n    _patient_id: matchedPatient.json.id,\n    _patient_name: patientName,\n    _from_phone: inboundPhone,\n    _to_phone: 'whatsapp:' + normInbound,\n    _classification: classification,\n    _message_body: messageBody,\n    _received_at: receivedAt,\n    _auto_reply: autoReply,\n    _should_reply: autoReply !== null\n  }\n}];"
      },
