      "id": "11111111-1111-1111-1111-000000000003",
      "name": "Read Patients",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.2,
      "position": [460, 380],
      "credentials": {
        "googleSheetsOAuth2Api": {
          "id": "REPLACE_WITH_GSHEETS_CREDENTIAL_ID",
          "name": "Google Sheets account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// Filter patients whose follow-up is tomorrow, status is pending, and haven't been over-messaged\nconst items = $input.all();\nconst tz = $env.TIMEZONE || 'Asia/Kolkata';\nconst maxMessages = parseInt($env.MAX_MESSAGE_COUNT) || 5;\nconst minHours = parseInt($env.MIN_HOURS_BETWEEN_MESSAGES) || 23;\n\n// Get tomorrow's date in local timezone (YYYY-MM-DD)\nconst now = new Date();\nconst tomorrow = new Date(now);\ntomorrow.setDate(tomorrow.getDate() + 1);\nconst tomorrowStr = tomorrow.toLocaleDateString('en-CA', { timeZone: tz }); // en-CA = YYYY-MM-DD\n\nconst filtered = items.filter(item => {\n  const p = item.json;\n\n  // Must have a follow-up date matching tomorrow\n  if (!p.follow_up_date || p.follow_up_date.trim() !== tomorrowStr) return false;\n\n  // Must be in pending state\n  if (p.status && p.status !== 'pending') return false;\n\n  // Must not exceed message limit\n  const msgCount = parseInt(p.message_count) || 0;\n  if (msgCount >= maxMessages) return false;\n\n  // Must have a valid phone number\n  if (!p.phone || !/^\\+[1-9]\\d{6,14}$/.test(p.phone.replace(/[\\s\\-().]/g, ''))) return false;\n\n  // Must not have been messaged within the last minHours hours\n  if (p.last_message_sent) {\n    const lastSent = new Date(p.last_message_sent);\n    const hoursSince = (now - lastSent) / (1000 * 60 * 60);\n    if (hoursSince < minHours) return false;\n  }\n\n  return true;\n});\n\nif (filtered.length === 0) {\n  // Return a no-op item so the workflow ends cleanly\n  return [{ json: { _skip: true, reason: 'No patients to message today', tomorrowStr } }];\n}\n\nreturn filtered.map(item => ({\n  json: {\n    ...item.json,\n    _workflow: 'workflow-1-followup-reminder',\n    _message_type: 'follow_up_reminder',\n    _to_phone: 'whatsapp:' + item.json.phone.replace(/[\\s\\-().]/g, ''),\n    _message_body: `Hi ${item.json.name || 'there'}, just a friendly reminder that your follow-up appointment with ${item.json.doctor_name || 'your doctor'} at ${item.json.clinic_name || ($env.DEFAULT_CLINIC_NAME || 'our clinic')} is scheduled for *tomorrow*. We look forward to seeing you! 🏥\\n\\nReply *YES* to confirm or *RESCHEDULE* if you need to change the date.`\n  }\n}));"
      },
      "id": "11111111-1111-1111-1111-000000000004",
      "name": "Filter Tomorrow Follow-ups",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [680, 380]
    },
