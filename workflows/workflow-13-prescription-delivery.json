            "workflow_name": "workflow-13-prescription-delivery",
            "message_type": "prescription_pdf",
            "message_sent": "={{ $('Validate Delivery Payload').first().json._message_body }}",
            "sent_at": "={{ new Date().toISOString() }}",
            "delivery_status": "sent",
            "scheduled_date": "={{ $('Validate Delivery Payload').first().json._scheduled_date }}",
            "provider_message_id": "={{ $json.sid || $json.Sid || '' }}",
            "twilio_message_sid": "={{ $json.sid || $json.Sid || '' }}"
          },
          "matchingColumns": [],
          "schema": []
        },
        "options": {}
      },
