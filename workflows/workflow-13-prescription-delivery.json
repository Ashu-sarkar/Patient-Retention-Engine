{
  "name": "WF13 — Prescription Delivery",
  "nodes": [
    {
      "parameters": {
        "content": "## WF13 — Prescription Delivery\n\n**Trigger:** POST webhook from `doctor-dashboard/index.html` after a prescription is issued.\n**Path:** `/webhook/prescription-delivery`\n\n**Flow:**\n1. Receive prescription_id, patient_id, visit_id, patient_name, phone, doctor_name, clinic_name, pdf_url\n2. Validate phone and PDF URL\n3. Send a WhatsApp message with the prescription PDF link through Twilio\n4. Update `public.prescriptions.delivery_status`\n5. Write `public.message_logs` and `public.system_logs` entries\n\nUse an approved Twilio Content template if the clinic sends prescriptions outside the active WhatsApp service window.",
        "height": 360,
        "width": 440
      },
      "id": "13131313-1313-1313-1313-000000000001",
      "name": "Sticky Note",
      "type": "n8n-nodes-base.stickyNote",
      "typeVersion": 1,
      "position": [
        100,
        60
      ]
    },
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "prescription-delivery",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "13131313-1313-1313-1313-000000000002",
      "name": "Webhook — Prescription Delivery",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [
        100,
        500
      ],
      "webhookId": "prescription-delivery-webhook"
    },
    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body || $input.first().json;\nconst clean = value => String(value || '').trim();\nconst prescriptionId = clean(body.prescription_id);\nconst patientId = clean(body.patient_id);\nconst visitId = clean(body.visit_id);\nconst patientName = clean(body.patient_name) || 'there';\nconst phone = clean(body.phone);\nconst doctorName = clean(body.doctor_name) || $env.DEFAULT_DOCTOR_NAME || 'your doctor';\nconst clinicName = clean(body.clinic_name) || $env.DEFAULT_CLINIC_NAME || 'our clinic';\nconst pdfUrl = clean(body.pdf_url);\nconst errors = [];\nif (!prescriptionId) errors.push('prescription_id is required');\nif (!patientId) errors.push('patient_id is required');\nif (!phone || !/^\\+[1-9]\\d{6,14}$/.test(phone)) errors.push('phone must be E.164 format');\nif (!pdfUrl || !/^https:\\/\\//i.test(pdfUrl)) errors.push('pdf_url must be an HTTPS URL');\nif (errors.length) return [{ json: { _valid: false, _errors: errors } }];\nconst bodyText = `Hi ${patientName}, your prescription from ${doctorName} at ${clinicName} is ready. You can open it here: ${pdfUrl}`;\nreturn [{ json: { _valid: true, prescription_id: prescriptionId, patient_id: patientId, visit_id: visitId || null, patient_name: patientName, phone, doctor_name: doctorName, clinic_name: clinicName, pdf_url: pdfUrl, _to_phone: 'whatsapp:' + phone, _message_type: 'prescription_pdf', _scheduled_date: new Date().toLocaleDateString('en-CA', { timeZone: $env.TIMEZONE || 'Asia/Kolkata' }), _message_body: bodyText } }];"
      },
      "id": "13131313-1313-1313-1313-000000000003",
      "name": "Validate Delivery Payload",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        320,
        500
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": false,
            "leftValue": "",
            "typeValidation": "loose"
          },
          "conditions": [
            {
              "id": "valid-payload",
              "leftValue": "={{ $json._valid }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "true"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "13131313-1313-1313-1313-000000000004",
      "name": "Valid?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        540,
        500
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{ 'https://api.twilio.com/2010-04-01/Accounts/' + $env.TWILIO_ACCOUNT_SID + '/Messages.json' }}",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpBasicAuth",
        "sendBody": true,
        "contentType": "form-urlencoded",
        "bodyParameters": {
          "parameters": [
            {
              "name": "From",
              "value": "={{ $env.TWILIO_WHATSAPP_FROM }}"
            },
            {
              "name": "To",
              "value": "={{ $json._to_phone }}"
            },
            {
              "name": "Body",
              "value": "={{ $json._message_body }}"
            },
            {
              "name": "StatusCallback",
              "value": "={{ $env.TWILIO_STATUS_CALLBACK_URL || '' }}"
            }
          ]
        },
        "options": {
          "retry": {
            "maxTries": 2,
            "waitBetweenTries": 15000
          }
        }
      },
      "id": "13131313-1313-1313-1313-000000000005",
      "name": "Send Prescription WhatsApp",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        760,
        400
      ],
      "credentials": {
        "httpBasicAuth": {
          "id": "REPLACE_TWILIO_BASIC_AUTH",
          "name": "Twilio Basic Auth"
        }
      },
      "onError": "continueErrorOutput"
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "=UPDATE public.prescriptions\nSET delivery_status = 'sent', updated_at = NOW()\nWHERE id = '{{ $('Validate Delivery Payload').first().json.prescription_id }}';",
        "options": {}
      },
      "id": "13131313-1313-1313-1313-000000000006",
      "name": "Mark Prescription Sent",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.4,
      "position": [
        980,
        300
      ],
      "credentials": {
        "postgres": {
          "id": "REPLACE_SUPABASE_POSTGRES",
          "name": "Supabase (Postgres)"
        }
      }
    },
    {
