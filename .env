# =============================================================================
# Patient Retention Engine — Environment Variables
# Copy this file to .env and fill in your real values.
# Never commit .env with real secrets — only commit .env.example.
# =============================================================================

# ----------------------------------------------------------------------------
# n8n Core
# ----------------------------------------------------------------------------
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=strongpass
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
# Public URL used for webhooks (set to your Railway/ngrok domain in production)
WEBHOOK_URL=http://localhost:5678
# Generate once with: openssl rand -hex 32
# NEVER change this after first launch — changing it invalidates all saved credentials
N8N_ENCRYPTION_KEY=wwo6ymkcGpyLNKmU/4haU7NAHi0gjyvpZ1yd0dMrziw=

