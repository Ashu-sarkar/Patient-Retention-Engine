# =============================================================================
# Patient Retention Engine — Environment Variables
# Copy this file to .env and fill in your real values.
# Never commit .env with real secrets — only commit .env.example.
# =============================================================================

# ----------------------------------------------------------------------------
# n8n Core
# ----------------------------------------------------------------------------
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=strongpass
N8N_HOST=localhost
N8N_PORT=5678
# Public URL used for webhooks (set to your tunnel/domain in production)
WEBHOOK_URL=http://localhost:5678

# ----------------------------------------------------------------------------
# Supabase — get these from: supabase.com → Project Settings → API
# ----------------------------------------------------------------------------
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY_HERE

# Supabase PostgreSQL direct connection — Settings → Database → Connection string (URI)
# Used by n8n as its own internal DB (replaces SQLite)
SUPABASE_DB_HOST=db.YOUR_PROJECT_REF.supabase.co
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=YOUR_SUPABASE_DB_PASSWORD_HERE

# ----------------------------------------------------------------------------
# Webhook paths (informational — paths are hardcoded literals in the workflows)
# WF11 listens on:  /webhook/patient-form-intake
# WF7  listens on:  /webhook/new-patient-intake
# WF6  listens on:  /webhook/feedback-listener  (POST = inbound, GET = verification)
# ----------------------------------------------------------------------------

# ----------------------------------------------------------------------------
# WhatsApp Business API (Meta Cloud API)
# Get these from: Meta Developer Console → Your App → WhatsApp → API Setup
# ----------------------------------------------------------------------------
WA_PHONE_NUMBER_ID=YOUR_PHONE_NUMBER_ID_HERE
WA_ACCESS_TOKEN=YOUR_PERMANENT_ACCESS_TOKEN_HERE
WA_WEBHOOK_VERIFY_TOKEN=YOUR_CHOSEN_VERIFY_TOKEN_HERE
WA_LANGUAGE_CODE=en

# ----------------------------------------------------------------------------
# Application Settings
# ----------------------------------------------------------------------------
TIMEZONE=Asia/Kolkata
MAX_MESSAGE_COUNT=5
MIN_HOURS_BETWEEN_MESSAGES=23
DEFAULT_CLINIC_NAME=Our Clinic
DEFAULT_DOCTOR_NAME=Your Doctor
# Admin WhatsApp number for error alerts (plain E.164 digits, e.g. 919876543210)
ADMIN_WHATSAPP_NUMBER=
