# ----------------------------------------------------------------------------
# Webhook paths (informational — paths are hardcoded literals in the workflows)
# WF11 listens on:  /webhook/patient-form-intake
# WF12 listens on:  /webhook/hospital-boarding
# WF7  listens on:  /webhook/new-patient-intake
# WF6  listens on:  /webhook/feedback-listener  (POST = inbound, GET = verification)
# ----------------------------------------------------------------------------

# ----------------------------------------------------------------------------
# WhatsApp Business API (Meta Cloud API)
# Get these from: Meta Developer Console → Your App → WhatsApp → API Setup
# ----------------------------------------------------------------------------
WA_PHONE_NUMBER_ID=YOUR_PHONE_NUMBER_ID_HERE
WA_ACCESS_TOKEN=YOUR_PERMANENT_ACCESS_TOKEN_HERE
WA_WEBHOOK_VERIFY_TOKEN=YOUR_CHOSEN_VERIFY_TOKEN_HERE
WA_LANGUAGE_CODE=en

# ----------------------------------------------------------------------------
# Application Settings
# ----------------------------------------------------------------------------
TIMEZONE=Asia/Kolkata
MAX_MESSAGE_COUNT=5
MIN_HOURS_BETWEEN_MESSAGES=23
DEFAULT_CLINIC_NAME=Our Clinic
DEFAULT_DOCTOR_NAME=Your Doctor
# Admin WhatsApp number for error alerts (plain E.164 digits, e.g. 919876543210)
ADMIN_WHATSAPP_NUMBER=
