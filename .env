# =============================================================================
# Patient Retention Engine — Environment Variables
# Copy this file to .env and fill in your real values.
# Never commit .env with real secrets — only commit .env.example.
# =============================================================================

# ----------------------------------------------------------------------------
# n8n Core
# ----------------------------------------------------------------------------
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=strongpass
N8N_HOST=localhost
N8N_PORT=5678
# Public URL used for webhooks (set to your tunnel/domain in production)
WEBHOOK_URL=http://localhost:5678

# ----------------------------------------------------------------------------
# Supabase — get these from: supabase.com → Project Settings → API
# ----------------------------------------------------------------------------
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=YOUR_ANON_KEY_HERE
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY_HERE

# Supabase PostgreSQL direct connection — Settings → Database → Connection string (URI)
# Used by n8n as its own internal DB (replaces SQLite)
SUPABASE_DB_HOST=db.YOUR_PROJECT_REF.supabase.co
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=YOUR_SUPABASE_DB_PASSWORD_HERE

# ----------------------------------------------------------------------------
# Google Sheets / Drive — Daily Intake System
# ----------------------------------------------------------------------------
# Legacy master sheet ID (still used by WF6 feedback lookup as fallback)
GOOGLE_SHEETS_ID=YOUR_GOOGLE_SHEETS_ID_HERE

# Google Drive folder ID where daily intake sheets will be created each morning
# Find it in the URL when you open the folder: drive.google.com/drive/folders/FOLDER_ID_HERE
GOOGLE_DRIVE_FOLDER_ID=YOUR_GOOGLE_DRIVE_FOLDER_ID_HERE

# Pre-defined dropdown values for the daily intake sheet (comma-separated, no quotes)
CLINIC_HOSPITAL_NAMES=City Hospital,General Hospital,Metro Clinic
CLINIC_DOCTOR_NAMES=Dr. Sharma,Dr. Mehta,Dr. Patel,Dr. Kumar

# ----------------------------------------------------------------------------
# Email — Daily Sheet Notification
# ----------------------------------------------------------------------------
# Email address(es) that receive the daily sheet link at 7 AM
# For multiple recipients, comma-separate: clinic@example.com,admin@example.com
CLINIC_EMAIL=clinic@example.com

# ----------------------------------------------------------------------------
# n8n Internal Webhook — WF7 New Patient Welcome
# ----------------------------------------------------------------------------
# Path for the WF7 webhook (do not include the base URL — n8n appends it)
N8N_WF7_WEBHOOK_PATH=new-patient-intake

# ----------------------------------------------------------------------------
# Twilio / WhatsApp
# ----------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=YOUR_TWILIO_ACCOUNT_SID_HERE
TWILIO_AUTH_TOKEN=YOUR_TWILIO_AUTH_TOKEN_HERE
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ----------------------------------------------------------------------------
# Application Settings
# ----------------------------------------------------------------------------
TIMEZONE=Asia/Kolkata
MAX_MESSAGE_COUNT=5
MIN_HOURS_BETWEEN_MESSAGES=23
DEFAULT_CLINIC_NAME=Our Clinic
DEFAULT_DOCTOR_NAME=Your Doctor
# Admin WhatsApp number for error alerts (E.164 format, e.g. whatsapp:+919876543210)
ADMIN_WHATSAPP_NUMBER=
