# =============================================================================
# Patient Retention Engine — Environment Variables
# Copy to .env and fill in real values. Do not commit .env.
# =============================================================================

# ----------------------------------------------------------------------------
# n8n Core
# ----------------------------------------------------------------------------
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change-me
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678
# openssl rand -hex 32 — set once before first launch
N8N_ENCRYPTION_KEY=
# Shared HMAC secret for trusted internal webhook calls.
# Use a separate value from N8N_ENCRYPTION_KEY. Generate with: openssl rand -hex 32
INTERNAL_WEBHOOK_SECRET=

# Owner login — same as setup-n8n.js; tests use this for GET /rest/workflows (n8n 2.x)
N8N_OWNER_EMAIL=
N8N_OWNER_PASSWORD=
# Optional: n8n → Settings → n8n API → Create API key (needed for POST /api/v1/workflows/:id/run in tests)
N8N_API_KEY=

# ----------------------------------------------------------------------------
# Supabase — Project Settings → API
# ----------------------------------------------------------------------------
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Supabase PostgreSQL — use Session pooler (IPv4) for Docker/macOS; avoid db.*.supabase.co (often IPv6-only).
# Dashboard → Connect → Session pooler: host aws-0-REGION.pooler.supabase.com, port 5432, user postgres.YOUR_PROJECT_REF
# Use the exact host from Dashboard → Connect (e.g. aws-0- or aws-1- REGION pooler).
SUPABASE_DB_HOST=aws-1-REGION.pooler.supabase.com
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres.YOUR_PROJECT_REF
SUPABASE_DB_PASSWORD=
# Optional: paste full "Session pooler" URI from Supabase Connect (overrides SUPABASE_DB_* for preflight + you can mirror values into discrete vars for n8n)
# SUPABASE_DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_DB_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres
# Optional: set to 0 if REST probe warns right after migration (PostgREST cache lag)
# PREFLIGHT_REST_VERIFY=1
# Skip DB migration (not recommended): SKIP_SUPABASE_PREFLIGHT=1

# ----------------------------------------------------------------------------
# WhatsApp via Twilio Programmable Messaging
# ----------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_STATUS_CALLBACK_URL=http://localhost:5678/webhook/twilio-status-callback
# Set true in production after confirming WEBHOOK_URL exactly matches the public URL configured in Twilio.
TWILIO_VALIDATE_WEBHOOK_SIGNATURE=false

# Twilio Content API template SIDs (HX...) — canonical list: message-templates/twilio-content-sids.json
# Sync into .env / Railway: npm run sync:twilio-content
TWILIO_CONTENT_WELCOME=
TWILIO_CONTENT_FOLLOW_UP_REMINDER=
TWILIO_CONTENT_FOLLOWUP_CONFIRMATION=
TWILIO_CONTENT_SAME_DAY_REMINDER=
TWILIO_CONTENT_MISSED_RECOVERY=
TWILIO_CONTENT_MISSED_NUDGE=
TWILIO_CONTENT_HEALTH_CHECK=
TWILIO_CONTENT_REACTIVATION=
TWILIO_CONTENT_PATIENT_ONBOARDING=
TWILIO_CONTENT_HOSPITAL_ONBOARDING=
TWILIO_CONTENT_PRESCRIPTION_DELIVERY=
TWILIO_CONTENT_PATIENT_REMINDER=
TWILIO_CONTENT_MEDICINE_REMINDER=
TWILIO_CONTENT_MEDICINE_MORNING_DOSE=
TWILIO_CONTENT_MEDICINE_AFTERNOON_DOSE=
TWILIO_CONTENT_MEDICINE_EVENING_DOSE=
TWILIO_CONTENT_MEDICINE_COURSE_COMPLETE=

# v2 WhatsApp templates (see docs/whatsapp-templates-v2-logic.md)
TWILIO_CONTENT_CLINIC_PATIENT_WELCOME=
TWILIO_CONTENT_PRESCRIPTION_WITH_FOLLOWUP=
TWILIO_CONTENT_PRESCRIPTION_JOURNEY_START=
TWILIO_CONTENT_MEDICINE_JOURNEY_DAY1_MORNING=
TWILIO_CONTENT_MEDICINE_JOURNEY_DAY1_EVENING=
TWILIO_CONTENT_MEDICINE_JOURNEY_MIDPOINT=
TWILIO_CONTENT_MEDICINE_JOURNEY_DAILY=
TWILIO_CONTENT_MEDICINE_JOURNEY_LAST_DAY=
TWILIO_CONTENT_MEDICINE_JOURNEY_COMPLETE=
TWILIO_CONTENT_MEDICINE_REMINDER_MORNING=
TWILIO_CONTENT_MEDICINE_REMINDER_AFTERNOON=
TWILIO_CONTENT_MEDICINE_REMINDER_NIGHT=
TWILIO_CONTENT_FOLLOWUP_REMINDER_ADVANCE=
TWILIO_CONTENT_FOLLOWUP_REMINDER_DAY_OF=
TWILIO_CONTENT_PATIENT_HEALTH_CHECK=
TWILIO_CONTENT_MISSED_FOLLOWUP_RECOVERY_1=
TWILIO_CONTENT_MISSED_FOLLOWUP_RECOVERY_2=
TWILIO_CONTENT_FOLLOWUP_BOOKING_CONFIRMED=
TWILIO_CONTENT_FOLLOWUP_RESCHEDULED_CONFIRMED=

# ----------------------------------------------------------------------------
# Application
# ----------------------------------------------------------------------------
TIMEZONE=Asia/Kolkata
MAX_MESSAGE_COUNT=5
MIN_HOURS_BETWEEN_MESSAGES=23
DEFAULT_CLINIC_NAME=Our Clinic
DEFAULT_DOCTOR_NAME=Your Doctor
ADMIN_WHATSAPP_NUMBER=

# ----------------------------------------------------------------------------
# Supabase Edge Function: prescription-delivery
# ----------------------------------------------------------------------------
# Set these as Supabase function secrets before deploying:
#   supabase secrets set N8N_PRESCRIPTION_DELIVERY_URL=https://your-n8n.example.com/webhook/prescription-delivery
#   supabase secrets set INTERNAL_WEBHOOK_SECRET=...
#   supabase secrets set DOCTOR_DASHBOARD_ORIGIN=https://vaitalcare-doctor.vercel.app,http://localhost:3000
#   (Vercel preview URLs vaitalcare-doctor*.vercel.app are allowed by the edge function by default)
N8N_PRESCRIPTION_DELIVERY_URL=http://localhost:5678/webhook/prescription-delivery
DOCTOR_DASHBOARD_ORIGIN=http://localhost:3000
