# =============================================================================
# Patient Retention Engine — Environment Variables
# Copy to .env and fill in real values. Do not commit .env.
# =============================================================================

# ----------------------------------------------------------------------------
# n8n Core
# ----------------------------------------------------------------------------
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change-me
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678
# openssl rand -hex 32 — set once before first launch
N8N_ENCRYPTION_KEY=

# Owner login — same as setup-n8n.js; tests use this for GET /rest/workflows (n8n 2.x)
N8N_OWNER_EMAIL=
N8N_OWNER_PASSWORD=
# Optional: n8n → Settings → n8n API → Create API key (needed for POST /api/v1/workflows/:id/run in tests)
N8N_API_KEY=

# ----------------------------------------------------------------------------
# Supabase — Project Settings → API
# ----------------------------------------------------------------------------
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Supabase PostgreSQL — Settings → Database
SUPABASE_DB_HOST=db.YOUR_PROJECT.supabase.co
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=

# ----------------------------------------------------------------------------
# WhatsApp Business API (Meta Cloud API)
# ----------------------------------------------------------------------------
WA_PHONE_NUMBER_ID=
WA_ACCESS_TOKEN=
WA_WEBHOOK_VERIFY_TOKEN=
WA_LANGUAGE_CODE=en

# ----------------------------------------------------------------------------
# Application
# ----------------------------------------------------------------------------
TIMEZONE=Asia/Kolkata
MAX_MESSAGE_COUNT=5
MIN_HOURS_BETWEEN_MESSAGES=23
DEFAULT_CLINIC_NAME=Our Clinic
DEFAULT_DOCTOR_NAME=Your Doctor
ADMIN_WHATSAPP_NUMBER=
