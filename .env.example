# =============================================================================
# Patient Retention Engine — Environment Variables
# Copy to .env and fill in real values. Do not commit .env.
# =============================================================================

# ----------------------------------------------------------------------------
# n8n Core
# ----------------------------------------------------------------------------
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change-me
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678
# openssl rand -hex 32 — set once before first launch
N8N_ENCRYPTION_KEY=

# Owner login — same as setup-n8n.js; tests use this for GET /rest/workflows (n8n 2.x)
N8N_OWNER_EMAIL=
N8N_OWNER_PASSWORD=
# Optional: n8n → Settings → n8n API → Create API key (needed for POST /api/v1/workflows/:id/run in tests)
N8N_API_KEY=

# ----------------------------------------------------------------------------
# Supabase — Project Settings → API
# ----------------------------------------------------------------------------
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Supabase PostgreSQL — use Session pooler (IPv4) for Docker/macOS; avoid db.*.supabase.co (often IPv6-only).
# Dashboard → Connect → Session pooler: host aws-0-REGION.pooler.supabase.com, port 5432, user postgres.YOUR_PROJECT_REF
# Use the exact host from Dashboard → Connect (e.g. aws-0- or aws-1- REGION pooler).
SUPABASE_DB_HOST=aws-1-REGION.pooler.supabase.com
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres.YOUR_PROJECT_REF
SUPABASE_DB_PASSWORD=
# Optional: paste full "Session pooler" URI from Supabase Connect (overrides SUPABASE_DB_* for preflight + you can mirror values into discrete vars for n8n)
# SUPABASE_DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_DB_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres
# Optional: set to 0 if REST probe warns right after migration (PostgREST cache lag)
# PREFLIGHT_REST_VERIFY=1
# Skip DB migration (not recommended): SKIP_SUPABASE_PREFLIGHT=1

# ----------------------------------------------------------------------------
# WhatsApp via Twilio Programmable Messaging
# ----------------------------------------------------------------------------
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_STATUS_CALLBACK_URL=http://localhost:5678/webhook/twilio-status-callback

# Twilio Content API template SIDs (HX...) for proactive WhatsApp messages.
# Use approved Content templates before production traffic.
TWILIO_CONTENT_WELCOME=
TWILIO_CONTENT_FOLLOW_UP_REMINDER=
TWILIO_CONTENT_SAME_DAY_REMINDER=
TWILIO_CONTENT_MISSED_RECOVERY=
TWILIO_CONTENT_MISSED_NUDGE=
TWILIO_CONTENT_HEALTH_CHECK=
TWILIO_CONTENT_REACTIVATION=
TWILIO_CONTENT_PATIENT_ONBOARDING=
TWILIO_CONTENT_HOSPITAL_ONBOARDING=
TWILIO_CONTENT_PATIENT_REMINDER=

# ----------------------------------------------------------------------------
# Application
# ----------------------------------------------------------------------------
TIMEZONE=Asia/Kolkata
MAX_MESSAGE_COUNT=5
MIN_HOURS_BETWEEN_MESSAGES=23
DEFAULT_CLINIC_NAME=Our Clinic
DEFAULT_DOCTOR_NAME=Your Doctor
ADMIN_WHATSAPP_NUMBER=
